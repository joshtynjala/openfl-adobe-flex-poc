{
	"config": "js",
	"compilerOptions": {
		"targets": ["JS"],
		"html-template": "index.template.html",
		"source-path": [
			"src",
			"flex_sdk_3.0.0.477A/frameworks/projects/framework/src"
		],
		"js-library-path": [
			"${royalelib}/js/libs/LanguageJS.swc",
			"${royalelib}/js/libs/ReflectionJS.swc"
		],
		"js-external-library-path": [
			"${royalelib}/libs/player/11.1/playerglobal.swc"
		],
		"namespace": [
			{
				"manifest": "flex_sdk_3.0.0.477A/frameworks/projects/framework/manifest.xml",
				"uri": "http://www.adobe.com/2006/mxml"
			}
		],
		"source-map": true
	},
	"additionalOptions": [
		"-imports=flash.accessibility.*,flash.debugger.*,flash.display.*,flash.errors.*,flash.events.*,flash.external.*,flash.filters.*,flash.geom.*,flash.media.*,flash.net.*,flash.printing.*,flash.profiler.*,flash.system.*,flash.text.*,flash.ui.*,flash.utils.*,flash.xml.*",
		"-binding-value-change-event=mx.events.PropertyChangeEvent",
		"-binding-value-change-event-kind=mx.events.PropertyChangeEvent",
		"-binding-value-change-event-type=propertyChange",
		"-binding-event-handler-event=flash.events.Event",
		"-binding-event-handler-class=flash.events.EventDispatcher",
		"-binding-event-handler-interface=flash.events.IEventDispatcher",
		"-states-class=mx.states.State",
		"-component-factory-class=mx.core.ClassFactory",
		"-component-factory-interface=mx.core.IFactory",
		"-js-getter-prefix=get_",
		"-js-setter-prefix=set_",
		"-js-vector-emulation-class=openfl.Vector",
		"-js-vector-emulation-element-types=false",
		"-js-vector-emulation-literal-function=openfl.Vector.ofArray",
		"-js-vector-index-checks=false",
		"-children-as-data=false",
		"-warn-this-within-closure=false"
	],
	"mainClass": "Flex3ForOpenFL"
}